generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeliveryMethod {
  PICKUP
  SHIPPING
}

enum TurnaroundTier {
  STANDARD
  EXPRESS
}

model Quote {
  id              String    @id @default(cuid())
  fileName        String
  material        String    @default("PLA")
  quality         String    @default("Standard")
  infill          Int       @default(15)
  
  // Logistics
  deliveryMethod  DeliveryMethod @default(SHIPPING)
  turnaroundTier  TurnaroundTier @default(STANDARD)
  
  // AMS / Multi-color fields
  isMultiColor      Boolean  @default(false)
  selectedSlots     Int[]    // AMS slot numbers used, e.g., [1, 3]
  colorTransitions  Int      @default(0)
  purgeWasteCost    Float    @default(0.0)
  primeTowerCost    Float    @default(0.0)
  
  // Legacy color field (to be removed in Phase 2.3)
  color             String?
  layerCount        Int?      @default(0)
  
  quantity        Int       @default(1)
  customerNotes   String?
  materialCost    Float
  electricityCost Float
  laborCost       Float
  nozzleSwapFee   Float     @default(0.0)
  depreciation    Float
  totalCost       Float
  printTimeHours  Float
  weightGrams     Float
  status          String    @default("QUOTED")
  
  // Relations
  nozzleDiameterId String?
  nozzleDiameter   NozzleDiameter? @relation(fields: [nozzleDiameterId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime?
  customerEmail   String?
}


model PricingConfig {
  id                    Int      @id @default(autoincrement())
  printerKwhUsage       Float    @default(0.15)
  electricityCostPerKwh Float    @default(0.20)
  machineLifeHours      Float    @default(5000)
  machineCost           Float    @default(699)
  fixedLaborFee         Float    @default(2.0)
  failureBufferPercent  Float    @default(0.1)
  profitMarginPercent   Float    @default(0.5)
  minimumPrice          Float    @default(5.0)
  notifyOnQuote         Boolean  @default(false)
  
  // Phase 1.1: Auth
  passwordHash          String?
  
  // Phase 1.4: Pricing Expansion
  purgeVolumePerTransitionCm3  Float  @default(1.5)
  purgeWasteCostMultiplier     Float  @default(1.0)
  primeTowerVolumePercent      Float  @default(0.05)
  multiColorFailureBufferExtra Float  @default(0.05)
  amsSwapFee                   Float  @default(0.50)
  amsSwapTimeSeconds           Int    @default(60)
  quoteExpiryHours             Int    @default(72)
  
  updatedAt             DateTime @updatedAt
}


model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Material {
  id             String   @id @default(cuid())
  name           String   @unique // Still used for internal matching/lookup
  costPerKg      Float
  enabled        Boolean  @default(true)
  
  // Retail Pricing
  basePrice      Float    @default(10.0) // Flat setup fee for this material
  pricePerGram   Float?                  // Retail markup price per gram
  
  // Phase 1.2: Filament Schema Extension
  brand          String?
  modelNumber    String?
  colorName      String?
  colorHex       String?
  sku            String?
  manufacturerId String?
  materialType   String   @default("PLA")
  amsSlot        Int?     // 1-4
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NozzleDiameter {
  id        String   @id @default(cuid())
  diameter  Float    // 0.2, 0.4, 0.6, 0.8
  label     String   // "0.2mm", "0.4mm", etc.
  isDefault Boolean  @default(false)
  swapFee   Float    @default(0.0)
  enabled   Boolean  @default(true)
  
  quotes    Quote[]
}


model Quality {
  id             String   @id @default(cuid())
  name           String   @unique
  timeMultiplier Float    @default(1.0)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model InfillOption {
  id        String   @id @default(cuid())
  value     Int      @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}





